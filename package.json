{
  "name": "sanos-y-salvos-frontend",
  "version": "1.0.0",
  "description": "Interfaz web de la plataforma Sanos y Salvos para gestión de mascotas perdidas y encontradas",
  "main": "src/app.js",
  "scripts": {
    "start": "live-server src --port=3000 --open=index.html",
    "build": "npm run lint && echo 'Build completado'",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "mascotas",
    "perdidas",
    "frontend",
    "sanos-y-salvos"
  ],
  "author": "Equipo Sanos y Salvos",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "live-server": "^1.2.2",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "collectCoverage": true,
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cesarin2005/Sanos-y-Salvos-Frontend.git"
  }
}
